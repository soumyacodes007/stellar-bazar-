# Direct Postgres connection (Supabase pooler)
DATABASE_URL=postgresql://postgres.your-project:YOUR-PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# OpenZeppelin Facilitator API Keys
OZ_API_KEY_TESTNET=your-testnet-key
OZ_API_KEY_MAINNET=your-mainnet-key

# Server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development
