# ─── Stellar / x402 ─────────────────────────────────────────────────────────
# Your Stellar address to receive payments
STELLAR_ADDRESS=GB3XY...YOUR_STELLAR_ADDRESS

# OpenZeppelin Facilitator (using OZ directly, not Stellar Bazaar)
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
OZ_API_KEY=YOUR_OZ_TESTNET_API_KEY

# Your Bazaar URL (for auto-registration only)
BAZAAR_URL=https://stellar-bazar.onrender.com

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4030
SERVICE_URL=http://localhost:4030

# ─── Provider API Keys ────────────────────────────────────────────────────────
# Groq (LLM Inference + Whisper STT)
GROQ_API_KEY=gsk_...

# Deepgram (STT Nova-3, TTS Aura-2)
DEEPGRAM_API_KEY=...

# fal.ai (Image Generation - Flux)
FAL_KEY=...

# Pinata (IPFS Storage)
PINATA_JWT=...
PINATA_GATEWAY=your-gateway.mypinata.cloud

# HuggingFace (Serverless Inference)
HF_ACCESS_TOKEN=hf_...

# ─── Compute (Piston - requires Docker) ─────────────────────────────────────
# Run: docker run -d -p 2000:2000 ghcr.io/engineer-man/piston
PISTON_URL=http://localhost:2000
